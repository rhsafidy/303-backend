// src/infrastructure/database/prisma/schema/schema.prisma
// 303 Export — Schéma Prisma complet v1.0.0
// Prisma 7 + PrismaPg adapter + PostgreSQL 16

generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
 
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

/// Rôle utilisateur — CLIENT par défaut, ADMIN unique créé via seed
enum Role {
  CLIENT
  ADMIN
}

/// Statut de commande — progression linéaire du cycle de vie
enum OrderStatus {
  PENDING      // En attente de paiement Stripe
  CONFIRMED    // PaymentIntent réussi (webhook)
  PROCESSING   // En préparation logistique
  SHIPPED      // Expédié avec numéro de tracking
  DELIVERED    // Livré (confirmation transporteur ou manuelle)
  CANCELLED    // Annulé avant expédition
  REFUNDED     // Remboursé via Stripe
}

/// Statut d'un avis client — modération avant publication
enum ReviewStatus {
  PENDING   // En attente de validation admin
  APPROVED  // Publié sur la fiche produit
  REJECTED  // Refusé — non publié
}

/// Type de coupon de réduction
enum CouponType {
  PERCENTAGE   // % du sous-total
  FIXED_AMOUNT // Montant fixe en €
  FREE_SHIPPING // Livraison offerte
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTHENTIFICATION & UTILISATEURS
// ─────────────────────────────────────────────────────────────────────────────

/// Utilisateurs — clients et admin unique
/// Le mot de passe est haché via bcrypt (12 rounds) avant persistance
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  /// Mot de passe haché bcrypt — jamais exposé via API
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?
  role          Role     @default(CLIENT)

  /// Email vérifié via lien envoyé à l'inscription
  isEmailVerified  Boolean  @default(false) @map("is_email_verified")
  /// UUID envoyé par email — null une fois vérifié
  emailVerifyToken String?  @map("email_verify_token")

  /// Token reset mot de passe — valable 1h
  resetPasswordToken String?   @map("reset_password_token")
  /// Expiration du token reset
  resetTokenExpiry   DateTime? @map("reset_token_expiry")

  isActive             Boolean @default(true)  @map("is_active")
  newsletterSubscribed Boolean @default(false) @map("newsletter_subscribed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Relations
  refreshTokens RefreshToken[]
  orders        Order[]
  addresses     Address[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  adminLogs     AdminLog[]

  @@map("users")
}

/// Refresh tokens persistés en base — révocation possible à tout moment
/// Un utilisateur peut avoir plusieurs sessions simultanées (multi-device)
model RefreshToken {
  id        String   @id @default(uuid())
  /// Le token JWT refresh lui-même (ou son hash)
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// IP de connexion — pour les logs d'audit
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  /// Révoqué manuellement (logout, rotation) ou expiré
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOGUE
// ─────────────────────────────────────────────────────────────────────────────

/// Catégories de produits — arbre récursif (parent/enfants)
/// Exemple : Spiritueux > Rhums > Rhums arrangés
model Category {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?
  imageUrl    String? @map("image_url")
  parentId    String? @map("parent_id")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0)    @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

/// Fiche produit complète
/// Les prix sont en Decimal(10,2) — jamais de Float pour les montants
model Product {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  description      String   @db.Text
  shortDescription String?  @map("short_description")
  /// Prix HT
  price            Decimal  @db.Decimal(10, 2)
  /// Prix TTC — affiché au client
  priceTtc         Decimal  @map("price_ttc") @db.Decimal(10, 2)
  /// Prix barré — déclenche affichage du badge remise
  compareAtPrice   Decimal? @map("compare_at_price") @db.Decimal(10, 2)
  sku              String   @unique
  stockQuantity    Int      @default(0) @map("stock_quantity")
  /// En dessous de ce seuil → alerte email admin
  lowStockThreshold Int     @default(5) @map("low_stock_threshold")
  isActive         Boolean  @default(true)  @map("is_active")
  /// true → affiché sur la homepage dans la section produits phares
  isFeatured       Boolean  @default(false) @map("is_featured")
  categoryId       String   @map("category_id")
  /// Degré d'alcool — si non null, déclenche vérification 18+ côté front
  alcoholDegree    Decimal? @map("alcohol_degree") @db.Decimal(5, 2)
  volumeMl         Int?     @map("volume_ml")
  originCountry    String?  @map("origin_country")
  /// Tags PostgreSQL natif — filtrable via { has: value }
  tags             String[]
  metaTitle        String?  @map("meta_title")
  metaDescription  String?  @map("meta_description") @db.Text
  /// Poids en grammes — utilisé pour le calcul des frais de port
  weightGrams      Int?     @map("weight_grams")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  cartItems     CartItem[]

  @@map("products")
}

/// Images produit — ordonnées, une seule peut être primaire
/// onDelete: Cascade — supprimer un produit supprime ses images
model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  /// URL relative sur le VPS : /uploads/products/<productId>/<uuid>_large.webp
  url       String
  altText   String? @map("alt_text")
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0)     @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────────────────────
// PANIER
// ─────────────────────────────────────────────────────────────────────────────

/// Panier persistant — fonctionne connecté (userId) et anonyme (sessionId)
/// onDelete: Cascade — supprimé quand le user ou le produit est supprimé
model CartItem {
  id        String  @id @default(uuid())
  /// null pour panier anonyme
  userId    String? @map("user_id")
  /// null pour panier connecté
  sessionId String? @map("session_id")
  productId String  @map("product_id")
  quantity  Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Un produit ne peut apparaître qu'une fois par panier (connecté ou anonyme)
  @@unique([userId, productId])
  @@unique([sessionId, productId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMANDES
// ─────────────────────────────────────────────────────────────────────────────

/// Coupons de réduction
model Coupon {
  id             String     @id @default(uuid())
  code           String     @unique
  type           CouponType
  /// Valeur : % pour PERCENTAGE, montant € pour FIXED_AMOUNT
  value          Decimal    @db.Decimal(10, 2)
  minOrderAmount Decimal?   @map("min_order_amount") @db.Decimal(10, 2)
  maxUses        Int?       @map("max_uses")
  usedCount      Int        @default(0) @map("used_count")
  isActive       Boolean    @default(true) @map("is_active")
  startsAt       DateTime?  @map("starts_at")
  expiresAt      DateTime?  @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("coupons")
}

/// Adresses de livraison client
model Address {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  company    String?
  address1   String
  address2   String?
  city       String
  postalCode String  @map("postal_code")
  country    String
  phone      String?
  isDefault  Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

/// Commande client — snapshot des prix au moment de l'achat
model Order {
  id          String      @id @default(uuid())
  /// Format lisible : 303-2026-000001
  orderNumber String      @unique @map("order_number")
  userId      String      @map("user_id")
  status      OrderStatus @default(PENDING)
  addressId   String      @map("address_id")

  subtotal       Decimal @db.Decimal(10, 2)
  shippingCost   Decimal @map("shipping_cost")   @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  couponId String? @map("coupon_id")

  /// PaymentIntent Stripe — stocké dès la création, utilisé pour le remboursement
  stripePaymentIntentId String? @map("stripe_payment_intent_id")

  trackingNumber String? @map("tracking_number")
  carrier        String?
  notes          String?

  /// Log légal — vérification 18+ effectuée avant ajout au panier
  ageVerified Boolean @default(false) @map("age_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id])
  address       Address              @relation(fields: [addressId], references: [id])
  coupon        Coupon?              @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

/// Lignes de commande — snapshot produit au moment de l'achat
/// Les champs productName et productSku sont dupliqués intentionnellement
/// pour conserver l'historique même si le produit est modifié
model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  /// Snapshot du nom au moment de l'achat
  productName String  @map("product_name")
  /// Snapshot du SKU au moment de l'achat
  productSku  String  @map("product_sku")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

/// Historique des changements de statut — audit complet du cycle commande
model OrderStatusHistory {
  id      String      @id @default(uuid())
  orderId String      @map("order_id")
  status  OrderStatus
  note    String?

  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// AVIS & WISHLIST
// ─────────────────────────────────────────────────────────────────────────────

/// Avis client — un seul avis par produit par client
/// Publié uniquement si le client a commandé et reçu le produit (DELIVERED)
model Review {
  id        String       @id @default(uuid())
  productId String       @map("product_id")
  userId    String       @map("user_id")
  rating    Int          // 1 à 5
  title     String?
  comment   String?      @db.Text
  status    ReviewStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contrainte : 1 avis par produit par client
  @@unique([userId, productId])
  @@map("reviews")
}

/// Liste de souhaits — produits favoris du client
model WishlistItem {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  productId String @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEWSLETTER & CONTENU
// ─────────────────────────────────────────────────────────────────────────────

/// Abonnés newsletter — indépendant du compte client
model NewsletterSubscriber {
  id       String  @id @default(uuid())
  email    String  @unique
  isActive Boolean @default(true) @map("is_active")
  /// Token unique pour le lien de désabonnement dans les emails
  token    String  @unique @default(uuid())

  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

/// Zones de livraison — tarifs par zone géographique
model ShippingZone {
  id             String   @id @default(uuid())
  name           String
  /// Codes ISO pays : ["FR", "BE", "CH"] — vide = "Reste du monde"
  countries      String[]
  baseRate       Decimal  @map("base_rate")   @db.Decimal(10, 2)
  /// Montant commande à partir duquel la livraison est gratuite
  freeAbove      Decimal? @map("free_above")  @db.Decimal(10, 2)
  estimatedDays  String?  @map("estimated_days")
  isActive       Boolean  @default(true)      @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("shipping_zones")
}

/// Banners homepage — slider hero
model Banner {
  id        String  @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String  @map("image_url")
  link      String?
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0)    @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("banners")
}

/// Pages CMS — contenu statique éditable depuis l'admin
model Page {
  id          String  @id @default(uuid())
  /// Ex : "about", "cgv", "legal", "privacy"
  slug        String  @unique
  title       String
  content     String  @db.Text
  metaTitle   String? @map("meta_title")
  metaDesc    String? @map("meta_description")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pages")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────────────────────────────────────

/// Logs d'audit admin — traçabilité immuable des actions sensibles
/// Ex : ADMIN_LOGIN, ORDER_STATUS_CHANGED, PRODUCT_CREATED, USER_DEACTIVATED
model AdminLog {
  id         String  @id @default(uuid())
  adminId    String  @map("admin_id")
  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id")
  details    Json?
  ipAddress  String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@map("admin_logs")
}